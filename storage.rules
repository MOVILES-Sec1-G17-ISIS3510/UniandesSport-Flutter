rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /challenge_reviews/{challengeId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /reviews/{coachId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}