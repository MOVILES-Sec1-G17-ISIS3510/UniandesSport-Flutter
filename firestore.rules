rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isChallengeParticipant(challengeId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/challenges/$(challengeId)).data.participants;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /challenges/{challengeId} {
      allow read: if resource.data.status == 'active'
        || (isSignedIn() && (request.auth.uid == resource.data.createdBy || request.auth.uid in resource.data.participants));

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isSignedIn()
        && (
          request.auth.uid == resource.data.createdBy
          || request.auth.uid in resource.data.participants
          || request.auth.uid in request.resource.data.participants
        );

      allow delete: if isSignedIn() && request.auth.uid == resource.data.createdBy;

      match /reviews/{reviewId} {
        allow read: if true;

        allow create, update: if isSignedIn()
          && reviewId == request.auth.uid
          && isChallengeParticipant(challengeId);

        allow delete: if isSignedIn() && reviewId == request.auth.uid;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}